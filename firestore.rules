rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow unauthenticated reads for users collection (for employee ID login)
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Allow all authenticated users to read and write other collections
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
